{
  "name": "biblesearch",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "api": "bun run --cwd server dev",
    "client": "cd client && ng serve",
    "client-build": "cd client && ng b",
    "deploy": "./scripts/deploy.sh",
    "deploy:db": "./scripts/deploy-db.sh",
    "dev": "trap 'kill 0' SIGINT SIGTERM EXIT; bun run api & bun run client"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}